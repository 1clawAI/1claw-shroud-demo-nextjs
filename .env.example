# Human API key from 1claw dashboard (1ck_ prefix)
# Used for setup scripts and as fallback auth
ONECLAW_API_KEY=

# Your vault ID from 1claw dashboard
ONECLAW_VAULT_ID=

# Path to the Gemini API key in your vault
# Shroud convention: providers/gemini/api-key
GEMINI_SECRET_PATH=providers/gemini/api-key

# Agent credentials (register via dashboard or run: npm run setup)
ONECLAW_AGENT_ID=
ONECLAW_AGENT_API_KEY=

# Route through Shroud TEE proxy for prompt injection protection
ONECLAW_SHROUD_ENABLED=true
